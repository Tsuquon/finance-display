{
  "name": "finance-display",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:demo": "DEMO_MODE=true IBKR_MOCK=true next dev",
    "dev:demo-paper": "DEMO_MODE=true IBKR_MOCK=false IBKR_PAPER=true next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "worker:build": "esbuild scripts/checkAlerts.ts --bundle --platform=node --format=esm --target=node20 --packages=external --outfile=dist-worker/checkAlerts.mjs",
    "worker:run": "node dist-worker/checkAlerts.mjs",
    "alerts:check": "npm run worker:build && npm run worker:run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@neondatabase/auth": "^0.4.1-beta",
    "@neondatabase/serverless": "^1.1.0",
    "next": "16.2.6",
    "nodemailer": "^8.0.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "yahoo-finance2": "^3.15.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
